# MongoDB Connection String
# Get this from MongoDB Atlas or your self-hosted MongoDB instance
MONGODB_URI=mongodb://localhost:27017/certify

# NextAuth Configuration
# Generate a secure random string: openssl rand -base64 32
NEXTAUTH_SECRET=secret-key
# The URL of your application (change when deploying to production)
NEXTAUTH_URL=http://localhost:3000

# Resend Email Service (Mailtrap)
# Get your API key from https://resend.com or https://mailtrap.io
# Leave empty to use demo mode (emails logged to console)
RESEND_API_KEY=


# Email From Address (used in Resend emails)
# Must be a verified domain in Resend, or use 'onboarding@resend.dev' for testing
MAILTRAP_TOKEN=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=

# Cloudinary (for image storage - backgrounds, logos, signatures)
# Images are uploaded to Cloudinary and only URLs are stored in MongoDB
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: Default admin credentials for seed script
# These are only used by scripts/seed-admin.ts
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
